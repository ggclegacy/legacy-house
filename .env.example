# Local Development only. Copy to .env.local and replace placeholders.
# Use a pooled PostgreSQL URL for serverless-host parity when your provider offers one.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Explicit target for migration and seed commands. Local commands default to development.
DATABASE_TARGET=development

# Runtime data gates. Vercel supplies VERCEL_ENV automatically; never define it here.
# Preview must also have Vercel Deployment Protection enabled in the dashboard.
VERCEL_DEPLOYMENT_PROTECTION_CONFIRMED=false
PREVIEW_DATABASE_WRITES_ENABLED=false

# Keep false until the separate passkey/PIN Private Beta Launch Gate is complete.
PRIVATE_BETA_GATE_ENABLED=false

# Document Vault remains unavailable until a private external adapter is configured.
OBJECT_STORAGE_PROVIDER=unavailable

# Server-only secret added automatically when a private Vercel Blob store is connected.
# Never use a NEXT_PUBLIC prefix and never commit a real token.
# BLOB_READ_WRITE_TOKEN=

# Manual database-command confirmations; uncomment only for the named operation.
# CONFIRM_PREVIEW_SEED=legacy-house-preview
# CONFIRM_PRODUCTION_DATABASE_COMMAND=legacy-house-production
